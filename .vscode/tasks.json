{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Run nbody",
            "type": "shell",
            "command": ".\\build.bat ${input:buildConfiguration} && out\\build\\x64-${input:buildConfiguration}\\${input:buildConfiguration}\\nbody.exe",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build nbody",
            "type": "shell",
            "command": ".\\build.bat",
            "args": [
                "${input:buildConfiguration}"
            ],
            "problemMatcher": "$msCompile",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ],
    "inputs": [
        {
            "id": "buildConfiguration",
            "type": "pickString",
            "description": "Build configuration",
            "options": [
                "Debug",
                "Release"
            ],
            "default": "Debug"
        }
    ]
}
